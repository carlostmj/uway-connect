{
  "name": "carlostmj/uway-connect",
  "description": "SDK oficial para integrar OAuth 2.0/2.1 do UWAY Auth em PHP e Laravel.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.8",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "CarlosTMJ\\UwayConnect\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CarlosTMJ\\UwayConnect\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "CarlosTMJ\\UwayConnect\\Laravel\\UwayConnectServiceProvider"
      ],
      "aliases": {
        "UwayConnect": "CarlosTMJ\\UwayConnect\\Laravel\\UwayConnectFacade"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

